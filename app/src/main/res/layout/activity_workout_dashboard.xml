<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background_main">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/button_background"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBackWorkout"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/white"
                android:scaleType="centerInside"
                android:padding="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Workout &amp; Activity"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Today"
            android:textColor="@color/white"
            android:alpha="0.8"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Live Steps Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE STEPS"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStepsWorkout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/success_green"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvCaloriesBurned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 kcal burned"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />

                    <!-- Step Tracking Control Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnStartStepTracking"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="▶ Start Tracking"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:background="@drawable/button_background"
                            app:backgroundTint="@null"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStopStepTracking"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="⏸ Stop Tracking"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/error_red"
                            app:strokeColor="@color/error_red"
                            app:strokeWidth="2dp"
                            app:cornerRadius="24dp"
                            android:layout_marginStart="8dp"
                            android:enabled="false" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SOS Emergency Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🆘 EMERGENCY SOS"
                        android:textSize="13sp"
                        android:textColor="@color/error_red"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <!-- Emergency Contact Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:hint="Emergency contact phone number">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSosEmergencyContact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- SOS Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSOS"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="🚨 SEND SOS via Messenger"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/error_red"
                        app:cornerRadius="16dp"
                        app:icon="@android:drawable/ic_dialog_alert"
                        app:iconGravity="textStart"
                        app:iconTint="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sends your live location &amp; help alert to your emergency contact via Messenger"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Exercise Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnAiExerciseRecommendation"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="AI Exercise 🤖"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnManualExercise"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Manual Log ✍️"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/button_background"
                    app:backgroundTint="@null"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- AI Exercise Recommendation Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAiExercise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/white">

                        <!-- Header with Gradient -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/button_background"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Your Personalized Exercise Today 💪"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <!-- Large GIF / Image -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            app:cardCornerRadius="0dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/ivAiExerciseGif"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_workout_placeholder"
                                android:background="@color/gray_100" />
                        </androidx.cardview.widget.CardView>

                        <!-- Content Container -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <!-- Exercise Counter -->
                            <TextView
                                android:id="@+id/tvExerciseCounter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Exercise 1 of 3"
                                android:textSize="12sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginBottom="8dp" />

                            <!-- Exercise Name -->
                            <TextView
                                android:id="@+id/tvAiExerciseName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cat (Yoga Pose / Stretching)"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/pink_500"
                                android:layout_marginBottom="8dp" />

                            <!-- Target Info -->
                            <TextView
                                android:id="@+id/tvAiExerciseTarget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Target: Abs"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="12dp" />

                            <!-- Stats Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="12dp">

                                <TextView
                                    android:id="@+id/tvAiExerciseCalories"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="🔥 ~10 kcal"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvAiExerciseDuration"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⏱️ 5 mins"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_secondary" />
                            </LinearLayout>

                            <!-- Description -->
                            <TextView
                                android:id="@+id/tvAiExerciseReason"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Gentle stretching to ease tension and prepare the body for movement."
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:lineSpacingMultiplier="1.3"
                                android:layout_marginBottom="12dp" />

                            <!-- Age Insight -->
                            <LinearLayout
                                android:id="@+id/layoutAgeInsight"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@color/gray_100"
                                android:padding="12dp"
                                android:layout_marginBottom="8dp"
                                android:visibility="visible">

                                <TextView
                                    android:id="@+id/tvAiExerciseAgeExplanation"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="💡 Age Insight: Suitable for all ages."
                                    android:textSize="13sp"
                                    android:textColor="@color/warning_orange"
                                    android:lineSpacingMultiplier="1.2" />
                            </LinearLayout>

                            <!-- For You (Gender) -->
                            <LinearLayout
                                android:id="@+id/layoutGenderNote"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@color/gray_100"
                                android:padding="12dp"
                                android:layout_marginBottom="8dp"
                                android:visibility="visible">

                                <TextView
                                    android:id="@+id/tvAiExerciseGenderNote"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="✨ For You: Beneficial for both men and women."
                                    android:textSize="13sp"
                                    android:textColor="@color/pink_500"
                                    android:lineSpacingMultiplier="1.2" />
                            </LinearLayout>

                            <!-- PRO TIPS Section -->
                            <LinearLayout
                                android:id="@+id/layoutProTips"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@color/gray_100"
                                android:padding="12dp"
                                android:layout_marginBottom="8dp"
                                android:visibility="visible">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="✅ PRO TIPS:"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/success_green"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:id="@+id/llTips"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />
                            </LinearLayout>

                            <!-- AVOID MISTAKES Section -->
                            <LinearLayout
                                android:id="@+id/layoutAvoidMistakes"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@color/gray_100"
                                android:padding="12dp"
                                android:layout_marginBottom="12dp"
                                android:visibility="visible">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="⚠️ AVOID THESE MISTAKES:"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/error_red"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:id="@+id/llCommonMistakes"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />
                            </LinearLayout>

                            <!-- Motivational Message (Period Mode) -->
                            <LinearLayout
                                android:id="@+id/layoutMotivation"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@color/gray_100"
                                android:padding="12dp"
                                android:layout_marginBottom="12dp"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/tvAiExerciseMotivation"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="💕 Stretch like a kitty cat! Feel your spine wake up."
                                    android:textSize="14sp"
                                    android:textStyle="italic"
                                    android:textColor="@color/purple_500"
                                    android:lineSpacingMultiplier="1.2" />
                            </LinearLayout>

                            <!-- Hidden sections -->
                            <TextView
                                android:id="@+id/tvAiExerciseEquipment"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvAiExerciseGoalAlignment"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/llInstructions"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:visibility="gone" />

                            <!-- Counter Text -->
                            <TextView
                                android:id="@+id/tvExerciseCounterBottom"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Exercise 1 of 3"
                                android:gravity="center"
                                android:textColor="@color/text_hint"
                                android:textSize="13sp"
                                android:layout_marginBottom="16dp" />

                            <!-- Actions Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:weightSum="2">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnAiExerciseSkip"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="0.9"
                                    android:text="MAYBE LATER"
                                    android:textColor="@color/gray_600"
                                    android:textSize="13sp"
                                    app:strokeColor="@color/purple_500"
                                    app:strokeWidth="2dp"
                                    app:cornerRadius="12dp"
                                    android:layout_marginEnd="8dp" />

                                <Button
                                    android:id="@+id/btnAiExerciseDone"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="1.1"
                                    android:text="I DID IT! 💪"
                                    android:background="@drawable/button_background"
                                    app:backgroundTint="@null"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:textSize="15sp" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </ScrollView>
            </androidx.cardview.widget.CardView>

            <!-- Workout Stats Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR PROGRESS"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Total Workouts -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvTotalWorkouts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <!-- Streak -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvWorkoutStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/warning_orange" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Streak"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <!-- Minutes -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvTotalMinutes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/purple_500" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Minutes"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Modules -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cvGamification"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="🏆  LEADERBOARD"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:paddingVertical="16dp"
                android:background="@drawable/button_background"
                app:backgroundTint="@null"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
