<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_main"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Gradient Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_background"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="📊 Smart Progress"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnRefresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Refresh"
                android:padding="8dp"
                android:src="@drawable/ic_refresh"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Period Selection Chips -->
        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedChip="@id/chip7Days">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip7Days"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="7 Days"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/purple_500"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip15Days"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 Days"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/purple_500"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip1Month"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 Month"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/purple_500"
                app:checkedIconVisible="false" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Journey Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Journey Progress"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvJourneyStage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Stage 1 / 6"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressJourney"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="20"
                    android:progressTint="@color/purple_500"
                    android:progressBackgroundTint="@color/gray_200" />

                <!-- Stage Grid 2x3 -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="3"
                    android:layout_marginTop="16dp">

                    <!-- Stage 1: Hydration Hero (Active) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStage1"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_column="0"
                        android:layout_row="0"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeColor="@color/purple_500"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💧"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STAGE 1"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hydration Hero"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:textAlignment="center" />

                            <TextView
                                android:id="@+id/tvStage1Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE"
                                android:textSize="10sp"
                                android:textColor="@color/purple_500"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stage 2: Step Master -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStage2"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_column="1"
                        android:layout_row="0"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="@color/gray_200">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔒"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STAGE 2"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Step Master"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:textAlignment="center" />

                            <TextView
                                android:id="@+id/tvStage2Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LOCKED"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stage 3: Sleep Saint -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStage3"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_column="0"
                        android:layout_row="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="@color/gray_200">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔒"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STAGE 3"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sleep Saint"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:textAlignment="center" />

                            <TextView
                                android:id="@+id/tvStage3Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LOCKED"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stage 4: Zen Master -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStage4"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_column="1"
                        android:layout_row="1"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="@color/gray_200">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔒"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STAGE 4"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Zen Master"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:textAlignment="center" />

                            <TextView
                                android:id="@+id/tvStage4Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LOCKED"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stage 5: Nutrition Ninja -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStage5"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_column="0"
                        android:layout_row="2"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="@color/gray_200">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔒"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STAGE 5"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nutrition Ninja"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:textAlignment="center" />

                            <TextView
                                android:id="@+id/tvStage5Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LOCKED"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stage 6: Iron Legend -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStage6"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_column="1"
                        android:layout_row="2"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp"
                        app:cardBackgroundColor="@color/gray_200">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔒"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STAGE 6"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Iron Legend"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:textAlignment="center" />

                            <TextView
                                android:id="@+id/tvStage6Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LOCKED"
                                android:textSize="10sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

                <!-- Current Activity Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/button_background"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CURRENT ACTIVITY"
                            android:textSize="10sp"
                            android:textColor="@color/text_white"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/tvCurrentActivity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 10k steps"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/fabAddActivity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_add"
                        app:fabSize="mini"
                        app:backgroundTint="@color/white"
                        app:tint="@color/purple_500" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Loading ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:indeterminateTint="@color/purple_500"
            android:visibility="gone" />

        <!-- Weight Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚖️ Weight Progress"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCurrentWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 kg"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/purple_500" />

                        <TextView
                            android:id="@+id/tvWeightChange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change: 0.0 kg"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvWeightTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stable"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/success_green" />

                        <TextView
                            android:id="@+id/tvPredictedWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Predicted: 0.0 kg"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/weightGraph"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/gray_100" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Nutrition Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍽️ Nutrition Progress"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAvgCalories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 kcal/day"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/warning_orange" />

                        <TextView
                            android:id="@+id/tvDaysLogged"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/7 days"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNutritionTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Balanced"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/success_green" />
                    </LinearLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressNutrition"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/warning_orange"
                    android:progressBackgroundTint="@color/gray_200" />

                <TextView
                    android:id="@+id/tvNutritionRecommendations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommendations"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/nutritionGraph"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/gray_100" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hydration Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 Hydration Progress"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAvgHydration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 ml/day"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/info_blue" />

                        <TextView
                            android:id="@+id/tvDaysTracked"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/7 days"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHydrationTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/success_green" />
                    </LinearLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressHydration"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/info_blue"
                    android:progressBackgroundTint="@color/gray_200" />

                <TextView
                    android:id="@+id/tvHydrationRecommendations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommendations"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/hydrationGraph"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/gray_100" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Exercise Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💪 Exercise Progress"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTotalExercise"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 min"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/error_red" />

                        <TextView
                            android:id="@+id/tvAvgExercise"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 min/day"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvExerciseTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/success_green" />

                        <TextView
                            android:id="@+id/tvActiveDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/7 days"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressExercise"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/error_red"
                    android:progressBackgroundTint="@color/gray_200" />

                <TextView
                    android:id="@+id/tvExerciseRecommendations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommendations"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/exerciseGraph"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/gray_100" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Insights Button -->
        <Button
            android:id="@+id/btnViewInsights"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:text="💡 View Detailed Insights"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/button_background"
            app:backgroundTint="@null"
            android:elevation="4dp" />

    </LinearLayout>
</ScrollView>
